# Copy from ../phone/.env.local — shares LiveKit credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# TTS for test agent (speaks the prompts)
CARTESIA_API_KEY=your_cartesia_key
# Or use OpenAI TTS:
OPENAI_API_KEY=your_openai_key

# STT for test agent (records what it hears back)
DEEPGRAM_API_KEY=your_deepgram_key

# Convex (for reading session logs if needed)
CONVEX_URL=wss://your-deployment.convex.cloud
